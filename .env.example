# ISP Monitor configuration (Node.js)

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Interval per protokol (detik) — scheduler independen per-ISP
PING_INTERVAL_SECONDS=10
HTTP_INTERVAL_SECONDS=30
STATUS_INTERVAL_SECONDS=300
STAGGER_MS=500

# Mode probe region (multi-region):
#   PROBE_REGION : nama region probe ini (mis. "asia", "eu-west", "us-east")
#   CENTRAL_URL  : kalau diset, worker LAPOR ke central (mode probe). Kosong = mode lokal.
#   REPORT_TOKEN : shared token (central wajib set ini biar /report butuh auth)
PROBE_REGION=central
CENTRAL_URL=
REPORT_TOKEN=

# Data directory (mount volume di sini saat deploy)
DATA_DIR=./data

# Notifikasi Telegram (kosongkan = notif off, cuma log)
TG_BOT_TOKEN=
TG_CHAT_ID=
