# ISP Monitor configuration

# API server
API_HOST=0.0.0.0
API_PORT=8000

# Monitoring interval (menit antar putaran)
MONITOR_INTERVAL_MINUTES=3

# Mode probe region (multi-region):
#   - PROBE_REGION: nama region probe ini (mis. "asia", "eu-west", "us-east")
#   - CENTRAL_URL:  kalau diset, worker tidak tulis DB lokal tapi LAPOR ke
#                   central API ini (mode probe). Kosong = mode lokal.
#   - REPORT_TOKEN: token shared kalau central pakai REPORT_TOKEN (auth /report)
PROBE_REGION=local
CENTRAL_URL=
REPORT_TOKEN=

# Log level
LOG_LEVEL=INFO
